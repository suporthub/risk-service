# risk-service — Local Development .env
# DO NOT COMMIT THIS FILE TO GIT

# ─── Risk Thresholds ─────────────────────────────────────────────────────────
# RISK_STOP_OUT_PCT: If MarginLevel falls AT OR BELOW this value (%), trigger
# a force-liquidation on the offending position immediately.
RISK_STOP_OUT_PCT=50.0

# RISK_MARGIN_CALL_PCT: If MarginLevel falls AT OR BELOW this value (%), flag
# the user for a margin call warning (log/notify — no liquidation yet).
RISK_MARGIN_CALL_PCT=100.0

# ─── Redis ───────────────────────────────────────────────────────────────────
# Subscribes to pattern: tick:*
# Tick payload format: "BID,ASK" — e.g. "1.10010,1.10020"
REDIS_ADDR=10.10.0.3:31001
REDIS_PASSWORD=

# ─── Kafka ───────────────────────────────────────────────────────────────────
# Consumer group subscribes to: orders.executed  and  orders.closed
KAFKA_BROKERS=localhost:29092
KAFKA_GROUP_ID=risk-service

# ─── Execution gRPC ──────────────────────────────────────────────────────────
# The risk-service is a gRPC CLIENT to the execution-service.
# It calls ForceLiquidate when stop-out is triggered.
EXECUTION_GRPC_ADDR=localhost:50051
